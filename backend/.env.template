# ─── Local Vision LLM ────────────────────────────────────────────────────────
# Ollama    → http://localhost:11434/v1   |  LLM_API_KEY=ollama
# LM Studio → http://localhost:1234/v1   |  LLM_API_KEY=lmstudio
# Used for both the PDF/vision stores AND the optional `--categorize` pass
# (modules/categorizer.py) — any vision-capable model works for the former,
# any instruction-following model works for the latter. e.g. qwen3.5:9b.
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llava:13b
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# ─── PDF Processing ──────────────────────────────────────────────────────────
PDF_DPI=200
MAX_PAGES_PER_PDF=20

